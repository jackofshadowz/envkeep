APP = "envkeep"
KEYCHAIN_SERVICE = "envkeep"               # macOS Keychain "service" namespace
_CFG_BASE = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
CONFIG_DIR = _CFG_BASE / APP
# Backward compatibility: keep working for pre-rename ("env-secrets") installs.
_LEGACY_DIR = _CFG_BASE / "env-secrets"
if not CONFIG_DIR.exists() and _LEGACY_DIR.exists():
    CONFIG_DIR = _LEGACY_DIR
CONFIG_FILE = CONFIG_DIR / "config.json"
IDENTITY_FILE = CONFIG_DIR / "identity.txt"   # YOUR age private key (chmod 600)
ACCESS_LOG = CONFIG_DIR / "access.log"        # append-only audit trail (names, not values)
ENC_IDENTITY = CONFIG_DIR / "identity.enc"    # passphrase-encrypted identity (when protected)
SESSION_ID = CONFIG_DIR / ".session-identity" # decrypted identity for the unlocked window
SESSION_EXP = CONFIG_DIR / ".session-exp"     # epoch when the unlock window ends


class Locked(Exception):
    """Raised when the vault key is passphrase-protected and not unlocked."""


def cache_enabled(cfg: dict) -> bool:
    """Whether decrypted values are cached in the Keychain. Off = decrypt-on-demand."""
    return cfg.get("cache", "none") == "keychain"


def maybe_autolock(cfg: dict):
    """When caching, purge cached values after `autolock` minutes of inactivity."""
    if not cache_enabled(cfg):
        return
    mins = cfg.get("autolock", 15)
    touch = CONFIG_DIR / ".cache_touch"
    now = time.time()
    if mins:
        try:
            last = float(touch.read_text())
        except Exception:
            last = 0.0
        if last and (now - last) > mins * 60:
            try:
                data = decrypt_vault(cfg)
                n = sum(1 for name in data["secrets"] if kc_delete(name))
                log_access(cfg, "autolock", f"idle>{mins}m ({n})")
            except SystemExit:
                pass
    try:
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        touch.write_text(str(now))
    except Exception:
        pass


def log_access(cfg: dict, action: str, name: str = "", source: str = "cli"):
    """Append one audit line. Records the secret NAME and action — never the value."""
    if not cfg.get("log", True):
        return
    try:
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        ts = datetime.now().astimezone().isoformat(timespec="seconds")
        with ACCESS_LOG.open("a") as f:
            f.write(f"{ts}\t{source}\t{action}\t{name}\n")
        ACCESS_LOG.chmod(0o600)
    except Exception:
        pass


# --------------------------------------------------------------------------- #
# TOTP (RFC 6238) — Authy / Google Authenticator compatible, pure stdlib
# --------------------------------------------------------------------------- #

def totp_gen_secret() -> str:
    return base64.b32encode(os.urandom(20)).decode().rstrip("=")


def totp_at(secret: str, when: float, step: int = 30, digits: int = 6) -> str:
    pad = "=" * (-len(secret) % 8)
    key = base64.b32decode(secret + pad, casefold=True)
    counter = struct.pack(">Q", int(when // step))
    h = hmac.new(key, counter, hashlib.sha1).digest()
    off = h[-1] & 0x0F
    code = (struct.unpack(">I", h[off:off + 4])[0] & 0x7FFFFFFF) % (10 ** digits)
    return str(code).zfill(digits)


def totp_verify(secret: str, code: str, window: int = 1) -> bool:
    code = (code or "").strip()
    if not (secret and code.isdigit()):
        return False
    now = time.time()
    return any(totp_at(secret, now + w * 30) == code for w in range(-window, window + 1))


def totp_uri(secret: str, account: str) -> str:
    from urllib.parse import quote
    label = quote(f"Envkeep:{account}")
    return f"otpauth://totp/{label}?secret={secret}&issuer=Envkeep&period=30&digits=6"


def die(msg: str, code: int = 1):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


def info(msg: str):
    print(msg, file=sys.stderr)


def need(tool: str):
    if shutil.which(tool) is None:
        die(f"`{tool}` not found on PATH. Install with: brew install age")


def load_config() -> dict:
    if not CONFIG_FILE.exists():
        return {}
    return json.loads(CONFIG_FILE.read_text())


def save_config(cfg: dict):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    try:
        CONFIG_DIR.chmod(0o700)          # owner-only access to keys/config/log
    except OSError:
        pass
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))
    CONFIG_FILE.chmod(0o600)


def require_config() -> dict:
    cfg = load_config()
    if not cfg.get("vault_dir"):
        die("not initialised. Run `envkeep init` first.")
    return cfg


def vault_dir(cfg: dict) -> Path:
    return Path(cfg["vault_dir"]).expanduser()


def vault_file(cfg: dict) -> Path:
    return vault_dir(cfg) / "vault.age"


def recipients_file(cfg: dict) -> Path:
    return vault_dir(cfg) / "recipients.txt"


# --------------------------------------------------------------------------- #
# age encryption helpers
# --------------------------------------------------------------------------- #

# --------------------------------------------------------------------------- #
# Passphrase protection of the identity key (openssl AES-256 + PBKDF2)
# --------------------------------------------------------------------------- #

def key_protected(cfg: dict) -> bool:
    return bool(cfg.get("key_protected"))


def _openssl(args: list, passphrase: str) -> tuple:
    out = subprocess.run(["openssl", *args, "-pass", "stdin"],
                         input=(passphrase + "\n").encode(), capture_output=True)
    return out.returncode == 0, out.stderr.decode().strip()


def encrypt_identity(passphrase: str) -> bool:
    ok, _ = _openssl(["enc", "-aes-256-cbc", "-pbkdf2", "-iter", "200000", "-salt",
                      "-in", str(IDENTITY_FILE), "-out", str(ENC_IDENTITY)], passphrase)
    if ok:
        ENC_IDENTITY.chmod(0o600)
    return ok


def session_valid() -> bool:
    if not SESSION_ID.exists():
        return False
    try:
        if time.time() > float(SESSION_EXP.read_text()):
            clear_session()
            return False
    except Exception:
        return False
    return True


def clear_session():
    for p in (SESSION_ID, SESSION_EXP):
        try:
            p.unlink()
        except OSError:
            pass


def start_session(cfg: dict, passphrase: str) -> bool:
    ok, _ = _openssl(["enc", "-d", "-aes-256-cbc", "-pbkdf2", "-iter", "200000",
                      "-in", str(ENC_IDENTITY), "-out", str(SESSION_ID)], passphrase)
    if not ok:
        clear_session()
        return False
    SESSION_ID.chmod(0o600)
    SESSION_EXP.write_text(str(time.time() + cfg.get("unlock_minutes", 15) * 60))
    return True


def active_identity(cfg: dict) -> Path:
    """Path to a usable plaintext identity, or raise Locked if protected & locked."""
    if not key_protected(cfg):
        return IDENTITY_FILE
    if session_valid():
        return SESSION_ID
    raise Locked()


def age_pubkey() -> str:
    """Derive our public key from the (possibly session) identity file."""
    need("age-keygen")
    idf = active_identity(load_config())
    out = subprocess.run(
        ["age-keygen", "-y", str(idf)],
        capture_output=True, text=True,
    )
    if out.returncode != 0:
        die(f"could not read public key from identity: {out.stderr.strip()}")
    return out.stdout.strip()


def read_recipients(cfg: dict) -> list[str]:
    rf = recipients_file(cfg)
    if not rf.exists():
        return []
    keys = []
    for line in rf.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        # allow "alias = age1..." or bare "age1..."
        key = line.split("=")[-1].strip()
        if key.startswith("age1"):
            keys.append(key)
    return keys


def read_members(cfg: dict) -> list[dict]:
    """Recipients as [{alias, key}] for the GUI (alias optional)."""
    rf = recipients_file(cfg)
    if not rf.exists():
        return []
    out = []
    for line in rf.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            alias, key = line.split("=", 1)
            alias, key = alias.strip(), key.strip()
        else:
            alias, key = "", line.strip()
        if key.startswith("age1"):
            out.append({"alias": alias, "key": key})
    return out


def decrypt_vault(cfg: dict) -> dict:
    """Return the decrypted vault as {"secrets": {NAME: VALUE}}."""
    vf = vault_file(cfg)
    if not vf.exists():
        return {"secrets": {}}
    need("age")
    idf = active_identity(cfg)            # raises Locked if protected & not unlocked
    if not idf.exists():
        die("no identity key found. Run `envkeep init`.")
    out = subprocess.run(
        ["age", "-d", "-i", str(idf), str(vf)],
        capture_output=True,
    )
    if out.returncode != 0:
        die("failed to decrypt vault. Are you a recipient? "
            f"({out.stderr.decode().strip()})")
    try:
        data = json.loads(out.stdout.decode() or "{}")
    except json.JSONDecodeError:
        die("vault decrypted but is not valid JSON.")
    data.setdefault("secrets", {})
    return data


def encrypt_vault(cfg: dict, data: dict):
    """Encrypt `data` to every recipient and write vault.age atomically."""
    need("age")
    recips = read_recipients(cfg)
    if not recips:
        die("no recipients in recipients.txt — run `envkeep init` or "
            "`envkeep add-member`.")
    args = ["age", "-e"]
    for r in recips:
        args += ["-r", r]
    vf = vault_file(cfg)
    tmp = vf.with_suffix(".age.tmp")
    args += ["-o", str(tmp)]
    proc = subprocess.run(args, input=json.dumps(data, indent=2).encode(),
                          capture_output=True)
    if proc.returncode != 0:
        die(f"encryption failed: {proc.stderr.decode().strip()}")
    tmp.replace(vf)


# --------------------------------------------------------------------------- #
# macOS Keychain helpers (local cache)
# --------------------------------------------------------------------------- #

def kc_set(name: str, value: str):
    subprocess.run(
        ["security", "add-generic-password", "-U",
         "-s", KEYCHAIN_SERVICE, "-a", name, "-w", value,
         "-j", "Managed by `envkeep` CLI"],
        capture_output=True,
    )


def kc_get(name: str) -> str | None:
    out = subprocess.run(
        ["security", "find-generic-password",
         "-s", KEYCHAIN_SERVICE, "-a", name, "-w"],
        capture_output=True, text=True,
    )
    if out.returncode != 0:
        return None
    return out.stdout.rstrip("\n")


def kc_delete(name: str) -> bool:
    out = subprocess.run(
        ["security", "delete-generic-password",
         "-s", KEYCHAIN_SERVICE, "-a", name],
        capture_output=True,
    )
    return out.returncode == 0


# --------------------------------------------------------------------------- #
# git helpers (best effort)
# --------------------------------------------------------------------------- #

def git(cfg: dict, *args: str, check: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(["git", "-C", str(vault_dir(cfg)), *args],
                          capture_output=True, text=True,
                          check=check)


def is_git_repo(cfg: dict) -> bool:
    return git(cfg, "rev-parse", "--is-inside-work-tree").returncode == 0


def git_sync_pull(cfg: dict):
    if cfg.get("auto_git") and is_git_repo(cfg):
        r = git(cfg, "pull", "--ff-only")
        if r.returncode != 0:
            info(f"warning: git pull failed: {r.stderr.strip()}")


def git_commit_push(cfg: dict, message: str):
    if not (cfg.get("auto_git") and is_git_repo(cfg)):
        return
    git(cfg, "add", "vault.age", "recipients.txt")
    r = git(cfg, "commit", "-m", message)
    if r.returncode != 0 and "nothing to commit" not in (r.stdout + r.stderr):
        info(f"warning: git commit failed: {r.stderr.strip()}")
        return
    push = git(cfg, "push")
    if push.returncode != 0:
        info(f"warning: git push failed (changes committed locally): "
             f"{push.stderr.strip()}")


