       border:1px solid transparent;background:none;cursor:pointer;color:var(--muted);
       transition:background .12s,color .12s,border-color .12s}
  .iconbtn:hover{background:#f1f1f0;color:var(--ink);border-color:var(--line)}
  .iconbtn.danger:hover{background:var(--danger-tint);color:var(--danger);border-color:#f0c7c9}
  .row-actions{display:inline-flex;gap:4px;justify-content:flex-end}
  tbody tr{animation:rowin .3s ease both}
  @keyframes rowin{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

  .empty{text-align:center;color:var(--muted-2);padding:70px 20px;font-size:14px}
  .empty .big{font-size:15px;color:var(--muted);font-weight:550;margin-bottom:4px}

  /* ---------- settings ---------- */
  .settings{padding:14px 26px 48px;max-width:720px}
  .set-card{background:var(--panel);border:1px solid var(--line);border-radius:12px;
       padding:6px 18px;margin-bottom:18px}
  .set-card h3{font-size:13px;font-weight:650;letter-spacing:-0.01em;margin:16px 2px 10px;
       display:flex;align-items:center;gap:8px}
  .set-row{display:flex;align-items:center;gap:16px;padding:13px 2px;
       border-top:1px solid var(--line)}
  .set-row:first-of-type{border-top:none}
  .set-row > div:first-child{flex:1;min-width:0}
  .set-label{font-size:13.5px;font-weight:550}
  .set-help{font-size:12px;color:var(--muted-2);margin-top:2px}
  .seg{display:inline-flex;border:1px solid var(--line-2);border-radius:9px;overflow:hidden}
  .seg button{border:none;background:var(--panel);color:var(--muted);padding:7px 13px;
       font-size:12.5px;font-weight:550;cursor:pointer}
  .seg button.on{background:var(--green-tint);color:var(--green-deep)}
  .set-num{width:74px;padding:8px 10px;border:1px solid var(--line-2);border-radius:8px;
       font-size:13px;font-family:var(--mono);text-align:right;outline:none}
  .set-num:focus{border-color:var(--green-line);box-shadow:0 0 0 3px rgba(127,238,100,.25)}
  .switch{position:relative;display:inline-block;width:42px;height:24px;flex:none}
  .switch input{opacity:0;width:0;height:0}
  .switch span{position:absolute;inset:0;background:#d7d7d4;border-radius:24px;
       cursor:pointer;transition:.18s}
  .switch span:before{content:"";position:absolute;height:18px;width:18px;left:3px;top:3px;
       background:#fff;border-radius:50%;transition:.18s;box-shadow:0 1px 2px rgba(0,0,0,.2)}
  .switch input:checked + span{background:var(--green)}
  .switch input:checked + span:before{transform:translateX(18px)}
  .set-kv{display:flex;align-items:center;gap:12px;padding:11px 2px;border-top:1px solid var(--line);
       font-size:13px}
  .set-kv:first-of-type{border-top:none}
  .set-kv > span:first-child{width:120px;color:var(--muted);flex:none}
  .set-kv code{font-family:var(--mono);font-size:12px;color:var(--ink);flex:1;
       overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .set-member{display:flex;align-items:center;gap:10px;padding:9px 2px;border-top:1px solid var(--line);
       font-size:12.5px}
  .set-member b{font-weight:600;min-width:90px}
  .set-member code{font-family:var(--mono);font-size:11.5px;color:var(--muted);
       overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
  .set-add{display:flex;gap:8px;margin:12px 0 4px}
  .set-add input{flex:1;min-width:0;border:1px solid var(--line-2);border-radius:8px;
       padding:8px 11px;font-size:12.5px;font-family:var(--mono);outline:none}
  .set-add input:focus{border-color:var(--green-line);box-shadow:0 0 0 3px rgba(127,238,100,.25)}
  .set-add input:first-child{flex:0 0 130px}

  /* ---------- modal ---------- */
  .overlay{position:fixed;inset:0;background:rgba(16,17,19,.32);
       backdrop-filter:blur(3px);display:grid;place-items:center;z-index:50;
       animation:fade .15s ease}
  .overlay[hidden]{display:none}
  @keyframes fade{from{opacity:0}to{opacity:1}}
  .dialog{background:var(--panel);border:1px solid var(--line);border-radius:16px;
       box-shadow:var(--shadow-2);width:440px;max-width:calc(100vw - 40px);
       padding:22px 22px 18px;animation:pop .18s cubic-bezier(.2,.9,.3,1.2)}
  .dialog.sm{width:380px}
  @keyframes pop{from{opacity:0;transform:scale(.96) translateY(6px)}to{opacity:1;transform:none}}
  .dialog h2{margin:0 0 16px;font-size:17px;font-weight:650;letter-spacing:-0.02em}
  .dialog label{display:block;font-size:12px;font-weight:600;color:var(--muted);
       margin:14px 0 6px;letter-spacing:-0.01em}
  .dialog input,.dialog textarea{width:100%;border:1px solid var(--line-2);
       background:#fcfcfb;border-radius:9px;padding:10px 12px;font-size:13px;
       color:var(--ink);outline:none;font-family:var(--mono);
       transition:border-color .12s,box-shadow .12s}
  .dialog input:focus,.dialog textarea:focus{border-color:var(--green-line);
       background:#fff;box-shadow:0 0 0 3px rgba(127,238,100,.25)}
  .dialog textarea{resize:vertical;min-height:74px;line-height:1.5}
  .dialog input:disabled{color:var(--muted);background:#f3f3f2;cursor:not-allowed;
       box-shadow:none;border-color:var(--line)}
  .dialog .hint{font-size:11.5px;color:var(--muted-2);margin:6px 2px 0;
       font-family:var(--sans)}
  .dialog-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:20px}
  .dialog p.muted{color:var(--muted);font-size:13px;margin:0}
  .dialog p.muted b{color:var(--ink);font-family:var(--mono);font-weight:600}

  /* ---------- toast ---------- */
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(8px);
       background:var(--ink);color:#fff;padding:10px 16px;border-radius:10px;
       font-size:13px;font-weight:500;opacity:0;pointer-events:none;z-index:80;
       box-shadow:var(--shadow-2);transition:opacity .18s,transform .18s;
       display:flex;align-items:center;gap:9px;max-width:80vw}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .toast .ok{color:var(--green)}
  .toast code{font-family:var(--mono);font-size:12px;color:#dfe3df}

  /* ---------- command palette ---------- */
  .cmdk{align-items:flex-start;padding-top:12vh}
  .cmdk .panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;
       box-shadow:var(--shadow-2);width:580px;max-width:calc(100vw - 40px);overflow:hidden;
       animation:pop .16s cubic-bezier(.2,.9,.3,1.2)}
  .cmdk input{width:100%;border:none;border-bottom:1px solid var(--line);padding:16px 18px;
       font-size:15px;font-family:var(--sans);outline:none;color:var(--ink);background:none;
       letter-spacing:-0.01em}
  .cmdk input::placeholder{color:var(--muted-2)}
  .cmdk .results{max-height:54vh;overflow-y:auto;padding:7px}
  .cmdk .opt{display:flex;align-items:center;gap:11px;padding:10px 12px;border-radius:9px;
       cursor:pointer;color:var(--ink);font-size:13.5px}
  .cmdk .opt .ic{width:26px;height:26px;border-radius:7px;background:#f2f2f1;display:grid;
       place-items:center;color:var(--muted);flex:none;font-size:12px;font-weight:700;
       font-family:var(--mono)}
  .cmdk .opt .lbl{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .cmdk .opt .lbl b{font-weight:600}
  .cmdk .opt .kind{font-size:10.5px;color:var(--muted-2);font-family:var(--mono);
       text-transform:uppercase;letter-spacing:.05em}
  .cmdk .opt.active{background:var(--green-tint)}
  .cmdk .opt.active .ic{background:#fff;color:var(--green-deep)}
  .cmdk .none{padding:26px;text-align:center;color:var(--muted-2);font-size:13px}
  .kbd{display:inline-flex;align-items:center;gap:4px;cursor:pointer}
  .kbd b{font:600 11px/1 var(--mono);background:#f1f1f0;border:1px solid var(--line-2);
       border-bottom-width:2px;border-radius:5px;padding:4px 5px 3px;color:var(--muted)}
  .kbd:hover b{background:#eaeae9;color:var(--ink)}
</style></head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-mark">&#9670;</div>
      <div class="brand-name">Envkeep</div>
    </div>
    <nav class="nav" id="nav"></nav>
    <div class="sidebar-foot">
      <button class="btn ghost block" id="settingsBtn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Settings</button>
      <button class="btn ghost block" id="lockBtn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Lock (purge cache)</button>
      <div class="members" id="memcount">&hellip;</div>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="crumbs">
        <h1 id="viewTitle">All secrets</h1>
        <span class="count" id="viewCount"></span>
      </div>
      <div class="sp"></div>
      <div class="search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search" placeholder="Search secrets" autocomplete="off">
      </div>
      <span class="kbd" id="cmdkBtn" title="Command palette"><b>&#8984;</b><b>K</b></span>
      <button class="btn primary" id="newBtn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        New secret</button>
    </header>

    <div class="folderbar" id="folderbar" hidden>
      <span class="fb-name" id="fbName"></span>
      <span class="sp"></span>
      <button class="btn sm" id="copyEnv">Copy <code>env</code> cmd</button>
      <button class="btn sm" id="copyDotenv">Copy <code>.env</code> cmd</button>
    </div>

    <section class="table-wrap">
      <table class="tbl">
        <thead><tr><th>Name</th><th>Value</th><th class="ta-r">Actions</th></tr></thead>
        <tbody id="rows"></tbody>
      </table>
      <div class="empty" id="empty" hidden></div>
    </section>

    <section id="settingsView" hidden>
      <div class="settings">
        <div class="set-card">
          <h3>Security</h3>
          <div class="set-row">
            <div><div class="set-label">Security level</div>
              <div class="set-help">Quick presets — pick one, or fine-tune below.</div></div>
            <div class="seg" id="seg-level">
              <button data-v="relaxed">Relaxed</button>
              <button data-v="balanced">Balanced</button>
              <button data-v="strict">Strict</button>
            </div>
          </div>
          <div class="set-row">
            <div><div class="set-label">Storage mode</div>
              <div class="set-help">Where decrypted values live between reads.</div></div>
            <div class="seg" id="seg-cache">
              <button data-v="none">Decrypt on demand</button>
              <button data-v="keychain">Keychain cache</button>
            </div>
          </div>
          <div class="set-row" id="row-autolock">
            <div><div class="set-label">Auto-lock</div>
              <div class="set-help">Purge the cache after N idle minutes (0 = off).</div></div>
            <input type="number" min="0" id="set-autolock" class="set-num">
          </div>
          <div class="set-row">
            <div><div class="set-label">Access log</div>
              <div class="set-help">Record reads &amp; writes — names only, never values.</div></div>
            <label class="switch"><input type="checkbox" id="set-log"><span></span></label>
          </div>
          <div class="set-row">
            <div><div class="set-label">Require Touch ID to reveal</div>
              <div class="set-help">Prompt for Touch ID / password before showing or copying a value (native app).</div></div>
            <label class="switch"><input type="checkbox" id="set-touchid"><span></span></label>
          </div>
          <div class="set-row">
            <div><div class="set-label">Auto-relock after</div>
              <div class="set-help">Re-prompt for Touch ID / 2FA once a session is idle this long.</div></div>
            <div><input type="number" min="1" id="set-relock" class="set-num"> <span class="set-help">min</span></div>
          </div>
          <div class="set-row">
            <div><div class="set-label">Lock now</div>
              <div class="set-help">Purge any cached plaintext from the Keychain.</div></div>
            <button class="btn" id="set-lock">Lock</button>
          </div>
        </div>

        <div class="set-card">
          <h3>Two-factor (authenticator app) <span class="set-help" id="totp-state"></span></h3>
          <div id="totp-off">
            <div class="set-help" style="padding:8px 2px">
              Require a 6-digit code from Authy, Google Authenticator, or 1Password
              before revealing or copying a value.</div>
            <button class="btn primary" id="totp-start">Enable 2FA</button>
          </div>
          <div id="totp-setup" hidden>
            <div class="set-help" style="padding:6px 2px">1. Add this key to your authenticator (or scan the URI):</div>
            <div class="set-kv"><span>Setup key</span><code id="totp-secret"></code>
              <button class="btn sm" id="totp-copysecret">Copy</button></div>
            <div class="set-kv"><span>otpauth URI</span><code id="totp-uri"></code>
              <button class="btn sm" id="totp-copyuri">Copy</button></div>
            <div class="set-help" style="padding:6px 2px">2. Enter the current 6-digit code to confirm:</div>
            <div class="set-add">
              <input id="totp-confirm" inputmode="numeric" maxlength="6" placeholder="000000">
              <button class="btn primary" id="totp-enable">Confirm &amp; enable</button>
              <button class="btn" id="totp-cancel">Cancel</button>
            </div>
          </div>
          <div id="totp-on" hidden>
            <div class="set-help" style="padding:8px 2px">✓ 2FA is on. Reveals require a code after the session locks.</div>
            <button class="btn danger" id="totp-disable">Disable 2FA</button>
          </div>
        </div>

        <div class="set-card">
          <h3>Vault key encryption <span class="set-help" id="keyprot-state"></span></h3>
          <div id="keyprot-off">
            <div class="set-help" style="padding:8px 2px">
              Encrypt your age private key at rest with a passphrase — a stolen key file
              is then useless. You'll unlock once per session (CLI or app).</div>
            <div class="set-add">
              <input id="keyprot-pass" type="password" placeholder="New passphrase (min 6)">
              <button class="btn primary" id="keyprot-enable">Encrypt key</button>
            </div>
          </div>
          <div id="keyprot-on" hidden>
            <div class="set-help" style="padding:8px 2px">✓ Vault key is passphrase-encrypted.
              ⚠ There is no recovery if you forget the passphrase.</div>
            <div class="set-add">
              <input id="keyprot-disable-pass" type="password" placeholder="Passphrase to confirm">
              <button class="btn danger" id="keyprot-disable">Remove protection</button>
            </div>
          </div>
        </div>

        <div class="set-card">
          <h3>Your identity</h3>
          <div class="set-kv"><span>Public key</span><code id="set-pub"></code>
            <button class="btn sm" id="set-copypub">Copy</button></div>
          <div class="set-kv"><span>Identity file</span><code id="set-identity"></code></div>
          <div class="set-kv"><span>Vault directory</span><code id="set-vault"></code></div>
          <div class="set-kv"><span>Access log</span><code id="set-logpath"></code></div>
        </div>

        <div class="set-card">
          <h3>Team <span class="set-help" id="set-memcount"></span></h3>
          <div id="set-members"></div>
          <div class="set-add">
            <input id="set-alias" placeholder="alias" autocomplete="off">
            <input id="set-newkey" placeholder="age1… teammate public key" autocomplete="off">
            <button class="btn primary" id="set-addmember">Add</button>
          </div>
          <div class="set-help">Adding a member re-encrypts the vault for everyone.</div>
        </div>

        <div class="set-card">
          <h3>About</h3>
          <div class="set-kv"><span>Version</span><code id="set-version"></code></div>
          <div class="set-kv"><span>Repository</span><code>github.com/jackofshadowz/envkeep</code></div>
        </div>
      </div>
    </section>
  </main>
</div>

<!-- new / edit secret -->
<div class="overlay" id="modal" hidden>
  <div class="dialog">
    <h2 id="modalTitle">New secret</h2>
    <label>Project / folder</label>
    <input id="m_folder" list="folderlist" placeholder="my-app  (optional)" autocomplete="off">
    <datalist id="folderlist"></datalist>
    <label>Name</label>
    <input id="m_name" placeholder="OPENAI_API_KEY" autocomplete="off">
    <label>Value</label>
    <textarea id="m_value" placeholder="sk-..." autocomplete="off" spellcheck="false"></textarea>
    <div class="hint">Saving encrypts the vault for every member and (if it is a git repo)
      commits &amp; pushes automatically.</div>
    <div class="dialog-actions">
      <button class="btn ghost" id="m_cancel">Cancel</button>
      <button class="btn primary" id="m_save">Save secret</button>
    </div>
  </div>
</div>

<!-- confirm delete -->
<div class="overlay" id="confirm" hidden>
  <div class="dialog sm">
    <h2>Delete secret?</h2>
    <p class="muted" id="confirmText"></p>
    <div class="dialog-actions">
      <button class="btn ghost" id="c_cancel">Cancel</button>
      <button class="btn danger" id="c_ok">Delete</button>
    </div>
  </div>
</div>

<!-- passphrase unlock screen (key-protected vaults) -->
<div class="overlay" id="keyUnlock" hidden>
  <div class="dialog">
    <h2>🔐 Vault locked</h2>
    <p class="muted">Enter your passphrase to unlock the vault key for this session.</p>
    <input id="keypass" type="password" placeholder="Passphrase"
      autocomplete="current-password" style="margin-top:16px">
    <div class="dialog-actions">
      <button class="btn primary" id="keyunlock-ok" style="width:100%;justify-content:center">Unlock</button>
    </div>
  </div>
</div>

<!-- 2FA unlock prompt -->
<div class="overlay" id="unlockModal" hidden>
  <div class="dialog sm">
    <h2>🔒 Locked</h2>
    <p class="muted">Enter your 6-digit authenticator code to unlock.</p>
    <input id="unlock-code" inputmode="numeric" maxlength="6" placeholder="000000"
      autocomplete="one-time-code" style="margin-top:14px;text-align:center;
      font-size:22px;letter-spacing:6px">
    <div class="dialog-actions">
      <button class="btn ghost" id="unlock-cancel">Cancel</button>
      <button class="btn primary" id="unlock-ok">Unlock</button>
    </div>
  </div>
</div>

<!-- command palette -->
<div class="overlay cmdk" id="palette" hidden>
  <div class="panel">
    <input id="pq" placeholder="Type a command, project, or secret..." autocomplete="off" spellcheck="false">
    <div class="results" id="presults"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const TOKEN="__TOKEN__";
const H={'X-Auth':TOKEN,'Content-Type':'application/json'};
const $=s=>document.querySelector(s);

const ICON={
  eye:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>',
  eyeoff:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.7 5.1A10.6 10.6 0 0 1 12 5c6.5 0 10 7 10 7a18 18 0 0 1-2.4 3.3M6.6 6.6A18 18 0 0 0 2 12s3.5 7 10 7a10.6 10.6 0 0 0 4.5-1M3 3l18 18"/></svg>',
  copy:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>',
  term:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="m7 9 3 3-3 3M13 15h4"/></svg>',
  trash:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>',
  edit:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>',
};

let SECRETS=[];        // full paths
let MEMBERS=[];
let current=null;      // selected folder, null = all
let search="";
let TOUCHID=false;     // require biometric before revealing (native app only)
let UNLOCK_MIN=15;     // auto-relock window (minutes)
let bioUntil=0;        // Touch ID session valid until (client ms)
let GATE_ON=false;     // any protection enabled (passphrase / 2FA / Touch ID)
async function requireAuth(reason){
  const mh=window.webkit&&window.webkit.messageHandlers;
  if(!TOUCHID||!(mh&&mh.auth))return true;   // off, or running in a plain browser
  if(Date.now()<bioUntil)return true;        // still inside the unlocked window
  try{const ok=!!(await mh.auth.postMessage(reason||'reveal a secret'));
    if(ok)bioUntil=Date.now()+UNLOCK_MIN*60000;return ok;}
  catch(e){return false;}
}
// reveal with the server-side 2FA gate (prompts for a code when locked)
async function apiReveal(full){
  try{return await api('/api/reveal?name='+encodeURIComponent(full));}
  catch(e){
    if((e.message||'').includes('locked')){
      if(await unlockFlow())return await api('/api/reveal?name='+encodeURIComponent(full));
      throw new Error('locked');
    }
    throw e;
  }
}
let _codeResolve=null;
function promptCode(title,help,okLabel){
  $('#unlockModal').querySelector('h2').textContent=title;
  $('#unlockModal').querySelector('p').textContent=help;
  $('#unlock-ok').textContent=okLabel||'Unlock';
  return new Promise(res=>{_codeResolve=res;$('#unlock-code').value='';
    $('#unlockModal').hidden=false;setTimeout(()=>$('#unlock-code').focus(),30);});
}
function resolveCode(v){$('#unlockModal').hidden=true;
  const r=_codeResolve;_codeResolve=null;if(r)r(v);}
async function unlockFlow(){
  const code=await promptCode('Locked','Enter your 6-digit authenticator code to unlock.','Unlock');
  if(code==null)return false;
  try{await api('/api/totp/unlock',{method:'POST',body:JSON.stringify({code})});return true;}
  catch(e){toast(e.message);return false;}
}
const revealed={};     // full -> value (cached after reveal)

async function api(path,opts={}){
  opts.headers=H;
  const r=await fetch(path,opts);
  const j=await r.json();
  if(!r.ok){
    if(j.error==='key_locked')showKeyUnlock();
    throw new Error(j.error||'request failed');
  }
  return j;
}
function showKeyUnlock(){if($('#keyUnlock').hidden){$('#keyUnlock').hidden=false;
  setTimeout(()=>$('#keypass').focus(),30);}}
async function boot(){
  try{const st=await api('/api/status');
    if(st.key_locked){showKeyUnlock();return;}}catch(e){}
  load();
}
async function submitKeyUnlock(){
  try{await api('/api/unlock-key',{method:'POST',
    body:JSON.stringify({passphrase:$('#keypass').value})});
    $('#keypass').value='';$('#keyUnlock').hidden=true;boot();
  }catch(e){toast(e.message==='key_locked'?'wrong passphrase':e.message);}
}
function folderOf(full){const i=full.lastIndexOf('/');return i>=0?full.slice(0,i):'';}
function keyOf(full){const i=full.lastIndexOf('/');return i>=0?full.slice(i+1):full;}
function envName(full){return keyOf(full).toUpperCase().replace(/[^A-Z0-9]/g,'_');}
// What a coding agent should run: assign the secret to an env var, on demand.
function getCmd(full){return 'export '+envName(full)+'="$(envkeep get '+full+')"';}

function toast(msg,cmd){
  const t=$('#toast');
  t.innerHTML='<span class="ok">&check;</span>'+msg+(cmd?(' <code>'+cmd+'</code>'):'');
  t.classList.add('show');
  clearTimeout(toast._t);toast._t=setTimeout(()=>t.classList.remove('show'),2100);
}
async function writeClip(text,label,cmd,sensitive){
  const mh=window.webkit&&window.webkit.messageHandlers;
  if(mh&&sensitive&&mh.copySecret){
    mh.copySecret.postMessage(text);return toast(label+' (clears in 45s)',cmd);}
  if(mh&&mh.copyText){
    mh.copyText.postMessage(text);return toast(label,cmd);}
  let ok=false;
  try{if(navigator.clipboard&&navigator.clipboard.writeText){
    await navigator.clipboard.writeText(text);ok=true;}}catch(e){}
  if(!ok){const ta=document.createElement('textarea');ta.value=text;
    ta.style.position='fixed';ta.style.opacity='0';document.body.appendChild(ta);
    ta.focus();ta.select();try{ok=document.execCommand('copy');}catch(e){}
    document.body.removeChild(ta);}
  toast(ok?label:'Copy failed',cmd);
}

function el(tag,cls,txt){const e=document.createElement(tag);if(cls)e.className=cls;
  if(txt!=null)e.textContent=txt;return e;}

function folders(){
  const m={};for(const f of SECRETS){const fo=folderOf(f);m[fo]=(m[fo]||0)+1;}
  return m;
}

function renderNav(){
  const nav=$('#nav');nav.innerHTML='';
  const counts=folders();
  const mk=(name,label,count,isAll)=>{
    const b=el('button','nav-item'+((current===name)?' active':''));
    b.appendChild(el('span','dot'));
    const nm=el('span','nm',label);if(isAll)nm.style.fontFamily='var(--sans)';
    b.appendChild(nm);
    b.appendChild(el('span','badge',String(count)));
    b.onclick=()=>{current=name;render();renderNav();};
    return b;
  };
  nav.appendChild((()=>{const b=mk(null,'All secrets',SECRETS.length,true);
    b.querySelector('.nm').style.fontWeight='600';return b;})());
  const named=Object.keys(counts).filter(f=>f!=='').sort();
  if(named.length){nav.appendChild(el('div','nav-label','Projects'));
    for(const f of named)nav.appendChild(mk(f,f,counts[f]));}
  if(counts['']!=null){nav.appendChild(el('div','nav-label','Other'));
    nav.appendChild(mk('','ungrouped',counts['']));}
}

function setView(v){
  const settings=v==='settings';
  $('#settingsView').hidden=!settings;
  $('.table-wrap').hidden=settings;
  $('.search').style.display=settings?'none':'';
  $('#cmdkBtn').style.display=settings?'none':'';
  $('#newBtn').style.display=settings?'none':'';
  if(settings){$('#folderbar').hidden=true;$('#viewTitle').textContent='Settings';
    $('#viewCount').textContent='';}
}
function render(){
  setView('secrets');
  // title + folderbar
  $('#viewTitle').textContent=current==null?'All secrets':(current===''?'Ungrouped':current);
  const fb=$('#folderbar');
  if(current){fb.hidden=false;$('#fbName').textContent=current;
    $('#copyEnv').onclick=()=>writeClip('envkeep env '+current,'Copied command','envkeep env '+current);
    $('#copyDotenv').onclick=()=>writeClip('envkeep env '+current+' --dotenv','Copied command','envkeep env '+current+' --dotenv');
  } else fb.hidden=true;

  let rows=SECRETS.slice();
  if(current!=null)rows=rows.filter(f=>folderOf(f)===current);
  if(search)rows=rows.filter(f=>f.toLowerCase().includes(search));
  rows.sort();
  $('#viewCount').textContent=rows.length?(rows.length+(rows.length===1?' secret':' secrets')):'';

  const tb=$('#rows');tb.innerHTML='';
  const empty=$('#empty');
  if(!rows.length){empty.hidden=false;
    empty.innerHTML=SECRETS.length
      ?'<div class="big">No matches</div>Try a different search or project.'
      :'<div class="big">No secrets yet</div>Click <b>New secret</b> to add your first one.';
    return;}
  empty.hidden=true;

  rows.forEach((full,i)=>{
    const tr=el('tr');tr.style.animationDelay=(i*22)+'ms';

    const tdName=el('td');
    tdName.appendChild(el('div','key',keyOf(full)));
    if(current==null&&folderOf(full))tdName.appendChild(el('span','tag',folderOf(full)));
    tr.appendChild(tdName);

    const tdVal=el('td');
    const wrap=el('div','val');
    const code=el('code');
    const eye=el('button','iconbtn');eye.title='Reveal / hide';
    const paint=()=>{                       // update this row only — no full re-render
      const shown=revealed[full]!=null;
      wrap.classList.toggle('shown',shown);
      code.textContent=shown?revealed[full]:'••••••••••••';
      eye.innerHTML=shown?ICON.eyeoff:ICON.eye;
    };
    paint();
    eye.onclick=async()=>{
      if(revealed[full]!=null){delete revealed[full];paint();return;}
      if(!await requireAuth('reveal '+keyOf(full))){toast('Authentication required');return;}
      try{const j=await apiReveal(full);
        revealed[full]=j.value;paint();}catch(e){toast(e.message);}
    };
    wrap.appendChild(eye);wrap.appendChild(code);
    tdVal.appendChild(wrap);
    tr.appendChild(tdVal);

    const tdAct=el('td','ta-r');
    const acts=el('div','row-actions');
    const bCmd=el('button','iconbtn');bCmd.title='Copy command — '+getCmd(full);
    bCmd.innerHTML=ICON.term;
    bCmd.onclick=()=>writeClip(getCmd(full),'Copied command for '+keyOf(full),getCmd(full));
    const bCopy=el('button','iconbtn');bCopy.title='Copy value';bCopy.innerHTML=ICON.copy;
    bCopy.onclick=async()=>{
      if(!await requireAuth('copy '+keyOf(full))){toast('Authentication required');return;}
      try{const j=await apiReveal(full);
      writeClip(j.value,'Copied value of '+keyOf(full),null,true);}catch(e){toast(e.message);}};
    const bEdit=el('button','iconbtn');bEdit.title='Edit value';bEdit.innerHTML=ICON.edit;
    bEdit.onclick=()=>openModal(full);
    const bDel=el('button','iconbtn danger');bDel.title='Delete';bDel.innerHTML=ICON.trash;
    bDel.onclick=()=>askDelete(full);
    acts.appendChild(bCmd);acts.appendChild(bCopy);acts.appendChild(bEdit);acts.appendChild(bDel);
    tdAct.appendChild(acts);
    tr.appendChild(tdAct);

    tb.appendChild(tr);
  });
}

// ---- modal (new + edit) ----
let editing=null;   // full path when editing an existing secret, else null
async function openModal(edit){
  editing=edit||null;
  const dl=$('#folderlist');dl.innerHTML='';
  Object.keys(folders()).filter(f=>f!=='').sort().forEach(f=>{
    const o=document.createElement('option');o.value=f;dl.appendChild(o);});
  const fF=$('#m_folder'),fN=$('#m_name'),fV=$('#m_value');
  if(editing){
    $('#modalTitle').textContent='Edit secret';
    $('#m_save').textContent='Update secret';
    fF.value=folderOf(editing);fN.value=keyOf(editing);
    fF.disabled=true;fN.disabled=true;            // identity locked while editing
    fV.value='';fV.placeholder='Enter a new value...';
    $('#modal').hidden=false;
    try{const j=await apiReveal(editing);fV.value=j.value;}catch(e){}
    setTimeout(()=>fV.focus(),30);
  } else {
    $('#modalTitle').textContent='New secret';
    $('#m_save').textContent='Save secret';
    fF.disabled=false;fN.disabled=false;
    fF.value=(current&&current!=='')?current:'';fN.value='';fV.value='';fV.placeholder='sk-...';
    $('#modal').hidden=false;setTimeout(()=>fN.focus(),30);
  }
}
function closeModal(){$('#modal').hidden=true;editing=null;
  $('#m_folder').disabled=false;$('#m_name').disabled=false;}
async function saveModal(){
  const f=$('#m_folder').value.trim().replace(/^\/+|\/+$/g,'');
  const n=$('#m_name').value.trim();
  const v=$('#m_value').value;
  if(!n||v===''){toast('Name and value are required');return;}
  const full=editing?editing:(f?f+'/'+n:n);
  try{await api('/api/set',{method:'POST',body:JSON.stringify({name:full,value:v})});
    const wasEditing=!!editing;closeModal();
    delete revealed[full];
    toast((wasEditing?'Updated ':'Saved ')+keyOf(full));await load();
    if(!wasEditing&&f){current=f;render();renderNav();}
  }catch(e){toast(e.message);}
}

// ---- confirm ----
let pendingDelete=null;
function askDelete(full){pendingDelete=full;
  $('#confirmText').innerHTML='This removes <b>'+full+'</b> for everyone with vault access. '
    +'Rotate it afterwards if it was ever shared.';
  $('#confirm').hidden=false;}
function closeConfirm(){$('#confirm').hidden=true;pendingDelete=null;}
async function doDelete(){
  const full=pendingDelete;closeConfirm();if(!full)return;
  try{await api('/api/delete',{method:'POST',body:JSON.stringify({name:full})});
    delete revealed[full];toast('Deleted '+keyOf(full));await load();}catch(e){toast(e.message);}
}

async function sync(){
  try{const j=await api('/api/sync',{method:'POST',body:'{}'});
    toast('Synced '+j.count+' secret'+(j.count===1?'':'s')+' to Keychain');}catch(e){toast(e.message);}
}
async function lock(){
  try{const j=await api('/api/lock',{method:'POST',body:'{}'});
    for(const k in revealed)delete revealed[k];
    bioUntil=0;                       // re-require Touch ID
    render();
    if(GATE_ON){
      toast('Locked'+(j.count?(' — purged '+j.count+' cached'):''));
      boot();                         // re-check lock state → show unlock screen if needed
    } else {
      toast('⚠ Reveals are NOT blocked — enable a gate in Settings (passphrase / 2FA / Touch ID)'
        +(j.count?('. Purged '+j.count+' cached.'):''));
    }
  }catch(e){toast(e.message);}
}

async function load(){
  const j=await api('/api/list');
  SECRETS=j.secrets;MEMBERS=j.members;TOUCHID=!!j.touchid;UNLOCK_MIN=j.unlock_minutes||15;
  GATE_ON=!!(j.touchid||j.totp||j.key_protected);
