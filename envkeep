let PALF=[],palIdx=0;
function buildCommands(){
  const c=[];
  c.push({k:'action',ic:'+',label:'New secret',run:openModal});
  c.push({k:'action',ic:'L',label:'Lock — purge cached secrets',run:lock});
  c.push({k:'action',ic:'S',label:'Sync to Keychain',run:sync});
  c.push({k:'go',ic:'#',label:'Go to: All secrets',run:()=>{current=null;render();renderNav();}});
  Object.keys(folders()).filter(f=>f).sort().forEach(f=>
    c.push({k:'project',ic:'/',label:'Go to project: '+f,run:()=>{current=f;render();renderNav();}}));
  Object.keys(folders()).filter(f=>f).sort().forEach(f=>
    c.push({k:'env',ic:'$',label:'Copy env cmd: '+f,sub:'envkeep env '+f,
      run:()=>writeClip('envkeep env '+f,'Copied command','envkeep env '+f)}));
  SECRETS.slice().sort().forEach(full=>{
    c.push({k:'cmd',ic:'>',label:'Copy command: '+full,sub:getCmd(full),
      run:()=>writeClip(getCmd(full),'Copied command for '+keyOf(full),getCmd(full))});
    c.push({k:'value',ic:'*',label:'Copy value: '+full,
      run:async()=>{try{const j=await apiReveal(full);
        writeClip(j.value,'Copied value of '+keyOf(full),null,true);}catch(e){toast(e.message);}}});
  });
  return c;
}
function openPalette(){PALL=buildCommands();palIdx=0;$('#palette').hidden=false;
  $('#pq').value='';renderPalette('');setTimeout(()=>$('#pq').focus(),20);}
function closePalette(){$('#palette').hidden=true;}
let PALL=[];
function renderPalette(q){
  q=q.toLowerCase().trim();
  PALF=q?PALL.filter(c=>c.label.toLowerCase().includes(q)||(c.sub&&c.sub.toLowerCase().includes(q))):PALL;
  PALF=PALF.slice(0,50);
  if(palIdx>=PALF.length)palIdx=Math.max(0,PALF.length-1);
  const box=$('#presults');box.innerHTML='';
  if(!PALF.length){box.innerHTML='<div class="none">No matching commands</div>';return;}
  PALF.forEach((c,i)=>{
    const o=el('div','opt'+(i===palIdx?' active':''));
    o.appendChild(el('span','ic',c.ic));
    const lbl=el('span','lbl',c.label);o.appendChild(lbl);
    o.appendChild(el('span','kind',c.k));
    o.onmousemove=()=>{if(palIdx!==i){palIdx=i;highlight();}};
    o.onclick=()=>{closePalette();c.run();};
    box.appendChild(o);
  });
}
function highlight(){const box=$('#presults');
  [...box.children].forEach((ch,i)=>ch.classList.toggle('active',i===palIdx));
  const a=box.children[palIdx];if(a&&a.scrollIntoView)a.scrollIntoView({block:'nearest'});}

