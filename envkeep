def cmd_gui(args):
    from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

    cfg = require_config()
    token = _stdlib_secrets.token_urlsafe(24)
    host, port = "127.0.0.1", args.port
    # session state for the 2FA unlock gate (per server process)
    state = {"totp_unlocked_until": 0.0, "pending_totp": None}

    def totp_locked() -> bool:
        return bool(cfg.get("totp")) and time.time() > state["totp_unlocked_until"]

    def authed(handler) -> bool:
        return handler.headers.get("X-Auth") == token or \
            f"token={token}" in (handler.path.split("?", 1)[-1])

    class Handler(BaseHTTPRequestHandler):
        def log_message(self, *a):  # silence
            pass

        def _send(self, code, body, ctype="application/json"):
            data = body if isinstance(body, bytes) else body.encode()
            self.send_response(code)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)

        def do_GET(self):
            path = self.path.split("?", 1)[0]
            if path == "/":
                self._send(200, INDEX_HTML.replace("__TOKEN__", token),
                           "text/html")
                return
            if not authed(self):
                self._send(403, json.dumps({"error": "forbidden"}))
                return
            if path == "/api/status":
                self._send(200, json.dumps({
                    "key_protected": key_protected(cfg),
                    "key_locked": key_protected(cfg) and not session_valid(),
                    "totp": bool(cfg.get("totp"))}))
                return
            try:
                if path == "/api/list":
                    data = decrypt_vault(cfg)
                    self._send(200, json.dumps(
                        {"secrets": sorted(data["secrets"]),
                         "members": read_recipients(cfg),
                         "touchid": cfg.get("touchid", False),
                         "totp": bool(cfg.get("totp")),
                         "key_protected": key_protected(cfg),
                         "locked": totp_locked(),
                         "unlock_minutes": cfg.get("unlock_minutes", 15)}))
                    return
                if path == "/api/reveal":
                    if totp_locked():
                        self._send(401, json.dumps({"error": "locked", "totp": True}))
                        return
                    from urllib.parse import parse_qs, urlparse
                    q = parse_qs(urlparse(self.path).query)
                    name = q.get("name", [""])[0]
                    data = decrypt_vault(cfg)
                    log_access(cfg, "reveal", name, "gui")
                    self._send(200, json.dumps(
                        {"name": name, "value": data["secrets"].get(name)}))
                    return
                if path == "/api/settings":
                    try:
                        pub = age_pubkey()
                    except Exception:
                        pub = ""
                    self._send(200, json.dumps({
                        "cache": cfg.get("cache", "none"),
                        "autolock": cfg.get("autolock", 15),
                        "log": cfg.get("log", True),
                        "touchid": cfg.get("touchid", False),
                        "totp_enabled": bool(cfg.get("totp")),
                        "unlock_minutes": cfg.get("unlock_minutes", 15),
                        "key_protected": key_protected(cfg),
                        "pubkey": pub,
                        "identity": str(IDENTITY_FILE),
                        "vault_dir": cfg.get("vault_dir", ""),
                        "access_log": str(ACCESS_LOG),
                        "version": __version__,
                        "members": read_members(cfg),
                    }))
                    return
                self._send(404, json.dumps({"error": "not found"}))
            except Locked:
                self._send(401, json.dumps({"error": "key_locked"}))

        def do_POST(self):
            if not authed(self):
                self._send(403, json.dumps({"error": "forbidden"}))
                return
            length = int(self.headers.get("Content-Length", 0))
            payload = json.loads(self.rfile.read(length) or "{}")
            path = self.path.split("?", 1)[0]
            try:
                if path == "/api/set":
                    name, value = payload["name"].strip(), payload["value"]
                    if not name or value == "":
                        raise ValueError("name and value required")
                    git_sync_pull(cfg)
                    data = decrypt_vault(cfg)
                    existed = name in data["secrets"]
                    data["secrets"][name] = value
                    encrypt_vault(cfg, data)
                    if cache_enabled(cfg):
                        kc_set(name, value)
                    git_commit_push(cfg, f"set {name} (gui)")
                    log_access(cfg, "update" if existed else "add", name, "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/delete":
                    name = payload["name"]
                    git_sync_pull(cfg)
                    data = decrypt_vault(cfg)
                    data["secrets"].pop(name, None)
                    encrypt_vault(cfg, data)
                    kc_delete(name)
                    git_commit_push(cfg, f"delete {name} (gui)")
                    log_access(cfg, "remove", name, "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/lock":
                    n = 0
                    try:
                        data = decrypt_vault(cfg)
                        n = sum(1 for nm in data["secrets"] if kc_delete(nm))
                    except Locked:
                        pass
                    clear_session()                      # re-lock the passphrase key
                    state["totp_unlocked_until"] = 0.0    # re-require a 2FA code
                    log_access(cfg, "lock", f"{n} cached", "gui")
                    self._send(200, json.dumps({"ok": True, "count": n}))
                    return
                if path == "/api/config":
                    key, value = payload.get("key"), payload.get("value")
                    if key == "cache":
                        if value not in ("keychain", "none"):
                            raise ValueError("cache must be keychain or none")
                        cfg["cache"] = value
                        if value == "none":
                            data = decrypt_vault(cfg)
                            for nm in data["secrets"]:
                                kc_delete(nm)
                    elif key == "autolock":
                        cfg["autolock"] = max(0, int(value))
                    elif key == "log":
                        cfg["log"] = bool(value)
                    elif key == "touchid":
                        cfg["touchid"] = bool(value)
                    elif key == "unlock_minutes":
                        cfg["unlock_minutes"] = max(1, int(value))
                    else:
                        raise ValueError("unknown setting")
                    save_config(cfg)
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/totp/setup":
                    secret = totp_gen_secret()
                    state["pending_totp"] = secret
                    import getpass as _gp
                    self._send(200, json.dumps({
                        "secret": secret,
                        "uri": totp_uri(secret, _gp.getuser())}))
                    return
                if path == "/api/totp/enable":
                    pend = state.get("pending_totp")
                    if not pend:
                        raise ValueError("run setup first")
                    if not totp_verify(pend, payload.get("code")):
                        raise ValueError("incorrect code — try again")
                    cfg["totp"] = pend
                    state["pending_totp"] = None
                    state["totp_unlocked_until"] = time.time() + cfg.get("unlock_minutes", 15) * 60
                    save_config(cfg)
                    log_access(cfg, "2fa-enable", "", "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/totp/disable":
                    if not cfg.get("totp"):
                        raise ValueError("2FA is not enabled")
                    if not totp_verify(cfg["totp"], payload.get("code")):
                        raise ValueError("incorrect code")
                    cfg.pop("totp", None)
                    save_config(cfg)
                    log_access(cfg, "2fa-disable", "", "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/totp/unlock":
                    if not cfg.get("totp"):
                        self._send(200, json.dumps({"ok": True}))
                        return
                    if not totp_verify(cfg["totp"], payload.get("code")):
                        raise ValueError("incorrect code")
                    mins = cfg.get("unlock_minutes", 15)
                    state["totp_unlocked_until"] = time.time() + mins * 60
                    log_access(cfg, "unlock", f"{mins}m", "gui")
                    self._send(200, json.dumps({"ok": True, "minutes": mins}))
                    return
                if path == "/api/add-member":
                    alias = (payload.get("alias") or "").strip()
                    pubkey = (payload.get("pubkey") or "").strip()
                    if not pubkey.startswith("age1"):
                        raise ValueError("not a valid age public key (age1…)")
                    if pubkey in read_recipients(cfg):
                        raise ValueError("already a member")
                    git_sync_pull(cfg)
                    with recipients_file(cfg).open("a") as f:
                        f.write(f"{alias or 'member'} = {pubkey}\n")
                    encrypt_vault(cfg, decrypt_vault(cfg))   # re-encrypt for new member
                    git_commit_push(cfg, f"add member {alias or pubkey[:12]} (gui)")
                    log_access(cfg, "add-member", alias or pubkey[:12], "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/sync":
                    git_sync_pull(cfg)
                    data = decrypt_vault(cfg)
                    if cache_enabled(cfg):
                        for n, v in data["secrets"].items():
                            kc_set(n, v)
                    self._send(200, json.dumps(
                        {"ok": True, "count": len(data["secrets"])}))
                    return
                if path == "/api/unlock-key":
                    if not key_protected(cfg):
                        self._send(200, json.dumps({"ok": True}))
                        return
                    if not start_session(cfg, payload.get("passphrase", "")):
                        raise ValueError("wrong passphrase")
                    log_access(cfg, "unlock", "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/protect-key":
                    if key_protected(cfg):
                        raise ValueError("already protected")
                    pw = payload.get("passphrase", "")
                    if len(pw) < 6:
                        raise ValueError("passphrase too short (min 6)")
                    if not IDENTITY_FILE.exists():
                        raise ValueError("identity not available")
                    if not encrypt_identity(pw):
                        raise ValueError("encryption failed")
                    IDENTITY_FILE.unlink()
                    cfg["key_protected"] = True
                    save_config(cfg)
                    start_session(cfg, pw)
                    log_access(cfg, "protect-key", "", "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                if path == "/api/unprotect-key":
                    if not key_protected(cfg):
                        raise ValueError("not protected")
                    ok, _ = _openssl(["enc", "-d", "-aes-256-cbc", "-pbkdf2",
                                      "-iter", "200000", "-in", str(ENC_IDENTITY),
                                      "-out", str(IDENTITY_FILE)], payload.get("passphrase", ""))
                    if not ok:
                        try:
                            IDENTITY_FILE.unlink()
                        except OSError:
                            pass
                        raise ValueError("wrong passphrase")
                    IDENTITY_FILE.chmod(0o600)
                    ENC_IDENTITY.unlink()
                    cfg["key_protected"] = False
                    save_config(cfg)
                    clear_session()
                    log_access(cfg, "unprotect-key", "", "gui")
                    self._send(200, json.dumps({"ok": True}))
                    return
                self._send(404, json.dumps({"error": "not found"}))
            except Locked:
                self._send(401, json.dumps({"error": "key_locked"}))
            except Exception as e:  # noqa: BLE001 — surface to GUI
                self._send(400, json.dumps({"error": str(e)}))

    server = ThreadingHTTPServer((host, port), Handler)
    actual_port = server.server_address[1]      # honors --port 0 (ephemeral)
    url = f"http://{host}:{actual_port}/?token={token}"
    print(f"✓ Secrets GUI running at:\n  {url}\n(Press Ctrl-C to stop.)",
          flush=True)
    if not args.no_open:
        webbrowser.open(url)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopped.")


