def cmd_init(args):
    need("age")
    need("age-keygen")
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    # 1. identity key
    if not IDENTITY_FILE.exists():
        info("Generating your personal age key…")
        r = subprocess.run(["age-keygen", "-o", str(IDENTITY_FILE)],
                           capture_output=True, text=True)
        if r.returncode != 0:
            die(f"age-keygen failed: {r.stderr.strip()}")
        IDENTITY_FILE.chmod(0o600)
    pub = age_pubkey()

    # 2. vault dir
    default_dir = args.vault_dir or input(
        "Path to the shared vault repo/folder "
        "[~/env-secrets-vault]: ").strip() or "~/env-secrets-vault"
    vdir = Path(default_dir).expanduser()
    vdir.mkdir(parents=True, exist_ok=True)

    cfg = load_config()
    cfg["vault_dir"] = str(vdir)
    cfg.setdefault("auto_git", True)
    save_config(cfg)

    # 3. recipients: make sure we're in the list
    rf = recipients_file(cfg)
    existing = read_recipients(cfg)
    if pub not in existing:
        alias = getpass.getuser()
        with rf.open("a") as f:
            if not rf.exists() or rf.stat().st_size == 0:
                f.write("# age public keys of everyone who may read the vault\n")
            f.write(f"{alias} = {pub}\n")
        info(f"Added your key to {rf}")

    # 4. create empty vault if missing
    if not vault_file(cfg).exists():
        encrypt_vault(cfg, {"secrets": {}})
        info("Created empty vault.age")

    # 5. .gitignore safety
    gi = vdir / ".gitignore"
    if not gi.exists():
        gi.write_text("# never commit private keys or plaintext\n"
                      "identity.txt\n*.tmp\n.env\n*.plaintext\n")

    print()
    print("✓ Initialised.")
    print(f"  Your public key : {pub}")
    print(f"  Identity (PRIVATE, never share): {IDENTITY_FILE}")
    print(f"  Vault directory : {vdir}")
    print()
    print("Next:")
    print("  • Share your PUBLIC key above with a teammate so they can add you,")
    print("    or send teammates' keys to yourself and run `envkeep add-member`.")
    print("  • `envkeep set NAME` to add a secret.")
    print("  • `envkeep sync` on each machine to load secrets into the Keychain.")
    print("  • Make the vault dir a private git repo for team sync (auto_git is on).")


def cmd_sync(args):
    cfg = require_config()
    if not cache_enabled(cfg):
        info("Cache is off (decrypt-on-demand mode) — nothing to sync.")
        info("Enable the Keychain cache with:  envkeep config cache keychain")
        return
    git_sync_pull(cfg)
    data = decrypt_vault(cfg)
    n = 0
    for name, value in data["secrets"].items():
        kc_set(name, value)
        n += 1
    print(f"✓ Synced {n} secret(s) from the vault into your Keychain.")


def cmd_get(args):
    cfg = require_config()
    maybe_autolock(cfg)
    if cache_enabled(cfg):
        # Keychain first (fast); fall back to the vault and cache.
        val = kc_get(args.name)
        if val is None:
            data = decrypt_vault(cfg)
            val = data["secrets"].get(args.name)
            if val is None:
                die(f"no secret named '{args.name}'. Try `envkeep list`.")
            kc_set(args.name, val)
    else:
        # Decrypt-on-demand: no plaintext is ever persisted to the Keychain.
        data = decrypt_vault(cfg)
        val = data["secrets"].get(args.name)
        if val is None:
            die(f"no secret named '{args.name}'. Try `envkeep list`.")
    log_access(cfg, "get", args.name)
    # raw value to stdout, no trailing decoration → safe for $(...) capture
    sys.stdout.write(val)
    if sys.stdout.isatty():
        sys.stdout.write("\n")


def cmd_lock(args):
    """Purge cached secrets and re-lock the passphrase-protected key."""
    cfg = require_config()
    n = 0
    try:
        data = decrypt_vault(cfg)
        n = sum(1 for name in data["secrets"] if kc_delete(name))
    except Locked:
        pass
    if key_protected(cfg):
        clear_session()
    log_access(cfg, "lock", f"{n} cached")
    msg = f"✓ Locked — purged {n} decrypted secret(s) from the Keychain."
    if key_protected(cfg):
        msg += " Vault key re-locked (passphrase required)."
    print(msg)


def cmd_protect_key(args):
    """Encrypt the age identity at rest with a passphrase."""
    cfg = require_config()
    if shutil.which("openssl") is None:
        die("`openssl` not found.")
    if key_protected(cfg):
        die("vault key is already passphrase-protected.")
    if not IDENTITY_FILE.exists():
        die("no identity key found. Run `envkeep init` first.")
    p1 = getpass.getpass("New passphrase for your vault key: ")
    if len(p1) < 6:
        die("passphrase too short (minimum 6 characters).")
    if p1 != getpass.getpass("Confirm passphrase: "):
        die("passphrases do not match.")
    if not encrypt_identity(p1):
        die("encryption failed.")
    IDENTITY_FILE.unlink()
    cfg["key_protected"] = True
    save_config(cfg)
    start_session(cfg, p1)          # keep the current session working
    log_access(cfg, "protect-key")
    print("✓ Vault key encrypted at rest. Unlock per session with `envkeep unlock`")
    print("  (or in the app). ⚠ There is NO recovery if you forget this passphrase.")


def cmd_unprotect_key(args):
    """Remove passphrase protection (store the identity unencrypted again)."""
    cfg = require_config()
    if not key_protected(cfg):
        die("vault key is not passphrase-protected.")
    p = getpass.getpass("Passphrase: ")
    ok, _ = _openssl(["enc", "-d", "-aes-256-cbc", "-pbkdf2", "-iter", "200000",
                      "-in", str(ENC_IDENTITY), "-out", str(IDENTITY_FILE)], p)
    if not ok:
        try:
            IDENTITY_FILE.unlink()
        except OSError:
            pass
        die("wrong passphrase.")
    IDENTITY_FILE.chmod(0o600)
    ENC_IDENTITY.unlink()
    cfg["key_protected"] = False
    save_config(cfg)
    clear_session()
    log_access(cfg, "unprotect-key")
    print("✓ Passphrase protection removed.")


def cmd_unlock(args):
    """Unlock the passphrase-protected key for this session."""
    cfg = require_config()
    if not key_protected(cfg):
        info("Vault key isn't passphrase-protected — nothing to unlock.")
        return
    if not start_session(cfg, getpass.getpass("Passphrase: ")):
        die("wrong passphrase.")
    log_access(cfg, "unlock", "cli")
    print(f"✓ Unlocked for {cfg.get('unlock_minutes', 15)} minute(s).")


def cmd_config(args):
    """View or change settings: cache (keychain|none), log (on|off), autolock (min)."""
    cfg = require_config()
    if args.key is None:
        print(f"cache     = {cfg.get('cache', 'none')}   (keychain | none)")
        print(f"autolock  = {cfg.get('autolock', 15)} min   (0 = off; cache mode only)")
        print(f"touchid   = {'on' if cfg.get('touchid', False) else 'off'}   (on | off; native app)")
        print(f"log       = {'on' if cfg.get('log', True) else 'off'}   (on | off)")
        print(f"vault_dir = {cfg.get('vault_dir')}")
        print(f"identity  = {IDENTITY_FILE}")
        print(f"access log= {ACCESS_LOG}")
        return
    if args.key == "autolock":
        try:
            cfg["autolock"] = max(0, int(args.value))
        except (TypeError, ValueError):
            die("usage: envkeep config autolock <minutes>  (0 to disable)")
        save_config(cfg)
        print(f"✓ autolock = {cfg['autolock']} min")
        return
    if args.key == "cache":
        if args.value not in ("keychain", "none"):
            die("usage: envkeep config cache keychain|none")
        cfg["cache"] = args.value
        save_config(cfg)
        if args.value == "none":
            try:
                data = decrypt_vault(cfg)
                purged = sum(1 for name in data["secrets"] if kc_delete(name))
                info(f"Purged {purged} cached value(s) from the Keychain.")
            except SystemExit:
                pass
        print(f"✓ cache = {args.value}")
    elif args.key == "log":
        if args.value not in ("on", "off"):
            die("usage: envkeep config log on|off")
        cfg["log"] = (args.value == "on")
        save_config(cfg)
        print(f"✓ log = {args.value}")
    elif args.key == "touchid":
        if args.value not in ("on", "off"):
            die("usage: envkeep config touchid on|off")
        cfg["touchid"] = (args.value == "on")
        save_config(cfg)
        print(f"✓ touchid = {args.value}")


def cmd_log(args):
    """Show the access log (most recent last)."""
    require_config()
    if not ACCESS_LOG.exists():
        info("(no access log yet)")
        return
    lines = ACCESS_LOG.read_text().splitlines()
    if args.tail:
        lines = lines[-args.tail:]
    print("\n".join(lines))


def cmd_list(args):
    cfg = require_config()
    data = decrypt_vault(cfg)
    names = sorted(data["secrets"])
    prefix = getattr(args, "prefix", None)
    if prefix:
        pfx = prefix.strip("/") + "/"
        names = [n for n in names if n.startswith(pfx)]
    if not names:
        info("(no matching secrets)" if prefix else "(vault is empty)")
        return
    for n in names:
        print(n)


def cmd_folders(args):
    """List the distinct folders/projects (the prefix before a secret's name)."""
    cfg = require_config()
    data = decrypt_vault(cfg)
    folders = sorted({n.rsplit("/", 1)[0] for n in data["secrets"] if "/" in n})
    if not folders:
        info("(no folders yet — secrets are added as 'project/NAME')")
        return
    for f in folders:
        print(f)


def cmd_env(args):
    """Print every secret in a folder as shell-ready env lines.

    A coding session can load a whole project at once:
        eval "$(envkeep env my-app)"      # export into the shell
        envkeep env my-app --dotenv > .env
    """
    cfg = require_config()
    data = decrypt_vault(cfg)
    pfx = args.prefix.strip("/") + "/"
    items = [(n[len(pfx):], v) for n, v in sorted(data["secrets"].items())
             if n.startswith(pfx)]
    if not items:
        die(f"no secrets under '{args.prefix}'. Try `envkeep folders`.")
    for key, val in items:
        key = key.replace("/", "_")          # nested path → flat env var name
        if args.dotenv:
            print(f"{key}={val}")
        else:
            print(f"export {key}={shlex.quote(val)}")


def parse_env(text: str) -> dict:
    """Parse KEY=VALUE lines from a .env file (ignores comments/blank/export)."""
    out = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export "):].strip()
        if "=" not in line:
            continue
        k, v = line.split("=", 1)
        k, v = k.strip(), v.strip()
        if len(v) >= 2 and v[0] == v[-1] and v[0] in ("'", '"'):
            v = v[1:-1]
        if k:
            out[k] = v
    return out


def cmd_import(args):
    """Scan a directory for .env files and import them into a project folder.

    Dry-run by default — prints only NAMES, never values. Re-run with --apply.
    """
    cfg = require_config()
    root = Path(args.dir).expanduser()
    if not root.exists():
        die(f"no such directory: {root}")
    project = (args.project or root.resolve().name).strip("/")

    skip_names = {".env.example", ".env.sample", ".env.template", ".env.dist"}
    skip_dirs = {"node_modules", ".git", ".venv", "venv", "__pycache__",
                 "dist", "build", ".next", "target"}
    files = []
    for p in sorted(root.rglob(".env*")):
        if not p.is_file():
            continue
        if p.name in skip_names or any(part in skip_dirs for part in p.parts):
            continue
        files.append(p)
    if not files:
        die(f"no .env files found under {root}")

    found = {}                       # KEY -> (value, source file)
    for f in files:
        try:
            for k, v in parse_env(f.read_text()).items():
                found[k] = (v, f)
        except Exception:
            info(f"warning: could not read {f}")
    if not found:
        die("found .env file(s) but no KEY=VALUE entries.")

    data = decrypt_vault(cfg)
    existing = set(data["secrets"])
    info(f"Found {len(found)} variable(s) in {len(files)} file(s) "
         f"-> project '{project}':\n")
    new = 0
    for k in sorted(found):
        full = f"{project}/{k}"
        if full in existing:
            tag = "overwrite" if args.overwrite else "skip (exists)"
        else:
            tag = "new"; new += 1
        print(f"  [{tag:>13}]  {full}")

    if not args.apply:
        info(f"\nDry run — {new} new. Re-run with --apply to import"
             + ("" if args.overwrite else " (add --overwrite to replace existing)") + ".")
        return

    n = 0
    for k, (v, _src) in found.items():
        full = f"{project}/{k}"
        if full in existing and not args.overwrite:
            continue
        data["secrets"][full] = v
        if cache_enabled(cfg):
            kc_set(full, v)
        n += 1
    if n:
        encrypt_vault(cfg, data)
        git_commit_push(cfg, f"import {n} secret(s) into {project}")
        log_access(cfg, "import", f"{project} ({n})")
    print(f"\n✓ Imported {n} secret(s) into '{project}'.")


def cmd_set(args):
    cfg = require_config()
    git_sync_pull(cfg)
    value = args.value
    if value is None:
        value = getpass.getpass(f"Value for {args.name}: ")
    if value == "":
        die("empty value — aborting.")
    data = decrypt_vault(cfg)
    existed = args.name in data["secrets"]
    data["secrets"][args.name] = value
    encrypt_vault(cfg, data)
    if cache_enabled(cfg):
        kc_set(args.name, value)
    git_commit_push(cfg, f"{'update' if existed else 'add'} {args.name}")
    log_access(cfg, "update" if existed else "add", args.name)
    print(f"✓ {'Updated' if existed else 'Added'} {args.name}")


def cmd_rm(args):
    cfg = require_config()
    git_sync_pull(cfg)
    data = decrypt_vault(cfg)
    if args.name not in data["secrets"]:
        die(f"no secret named '{args.name}'.")
    del data["secrets"][args.name]
    encrypt_vault(cfg, data)
    kc_delete(args.name)
    git_commit_push(cfg, f"remove {args.name}")
    log_access(cfg, "remove", args.name)
    print(f"✓ Removed {args.name}")


def cmd_members(args):
    cfg = require_config()
    rf = recipients_file(cfg)
    if not rf.exists():
        info("(no recipients yet)")
        return
    print(rf.read_text().rstrip())


def cmd_add_member(args):
    cfg = require_config()
    git_sync_pull(cfg)
    if not args.pubkey.startswith("age1"):
        die("that doesn't look like an age public key (should start 'age1').")
    rf = recipients_file(cfg)
    if args.pubkey in read_recipients(cfg):
        info("Already a recipient — nothing to do.")
        return
    with rf.open("a") as f:
        f.write(f"{args.alias} = {args.pubkey}\n")
    # re-encrypt so the new member can decrypt
    data = decrypt_vault(cfg)
    encrypt_vault(cfg, data)
    git_commit_push(cfg, f"add member {args.alias}")
    print(f"✓ Added {args.alias} and re-encrypted the vault for all members.")


