function currentLevel(j){
  if(j.cache==='keychain'&&!j.touchid&&!j.totp_enabled)return 'relaxed';
  if(j.cache==='none'&&j.touchid&&!j.totp_enabled)return 'balanced';
  if(j.cache==='none'&&j.touchid&&j.totp_enabled)return 'strict';
  return null;  // custom
}
async function applyLevel(v){
  const sets=v==='relaxed'?[['cache','keychain'],['touchid',false],['autolock',60],['unlock_minutes',60]]
    :v==='balanced'?[['cache','none'],['touchid',true],['unlock_minutes',15]]
    :[['cache','none'],['touchid',true],['unlock_minutes',5]];
  for(const [k,val] of sets)await setConfig(k,val);
  toast('Security level: '+v+(v==='strict'?' — add 2FA for max':''));
  openSettings();
}
async function setConfig(key,value){
  try{await api('/api/config',{method:'POST',body:JSON.stringify({key,value})});
    return true;}catch(e){toast(e.message);return false;}
}

