$('#m_value').addEventListener('keydown',e=>{if(e.key==='Enter'&&(e.metaKey||e.ctrlKey))saveModal();});
$('#pq').addEventListener('input',e=>{palIdx=0;renderPalette(e.target.value);});
$('#pq').addEventListener('keydown',e=>{
  if(e.key==='ArrowDown'){e.preventDefault();palIdx=Math.min(PALF.length-1,palIdx+1);highlight();}
  else if(e.key==='ArrowUp'){e.preventDefault();palIdx=Math.max(0,palIdx-1);highlight();}
  else if(e.key==='Enter'){e.preventDefault();const c=PALF[palIdx];if(c){closePalette();c.run();}}
});
function typing(){return /(INPUT|TEXTAREA)/.test(document.activeElement.tagName);}
document.addEventListener('keydown',e=>{
  if((e.metaKey||e.ctrlKey)&&e.key.toLowerCase()==='k'){
    e.preventDefault();$('#palette').hidden?openPalette():closePalette();return;}
  if(e.key==='Escape'){closeModal();closeConfirm();closePalette();return;}
  if(typing())return;
  if(e.key==='n'){e.preventDefault();openModal();}
  else if(e.key==='/'){e.preventDefault();$('#search').focus();}
  else if(e.key==='l'){lock();}
});
// key-unlock screen
$('#keyunlock-ok').onclick=submitKeyUnlock;
$('#keypass').addEventListener('keydown',e=>{if(e.key==='Enter')submitKeyUnlock();});
$('#keyprot-enable').onclick=async()=>{
  const pw=$('#keyprot-pass').value;
  if(pw.length<6){toast('Passphrase too short (min 6)');return;}
  try{await api('/api/protect-key',{method:'POST',body:JSON.stringify({passphrase:pw})});
    $('#keyprot-pass').value='';toast('Vault key encrypted');openSettings();}catch(e){toast(e.message);}
};
$('#keyprot-disable').onclick=async()=>{
  const pw=$('#keyprot-disable-pass').value;
  if(!pw){toast('Enter your passphrase to confirm');return;}
  try{await api('/api/unprotect-key',{method:'POST',body:JSON.stringify({passphrase:pw})});
    $('#keyprot-disable-pass').value='';toast('Protection removed');openSettings();}catch(e){toast(e.message);}
};
boot();
</script>
</body></html>
"""


# --------------------------------------------------------------------------- #
# Arg parsing
# --------------------------------------------------------------------------- #

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="envkeep",
        description="Secure ENV-secret manager (age vault + macOS Keychain).")
    p.add_argument("--version", action="version", version=f"envkeep {__version__}")
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("init", help="set up your key, vault and recipients")
    s.add_argument("--vault-dir", help="path to the shared vault repo/folder")
    s.set_defaults(func=cmd_init)

    s = sub.add_parser("sync", help="decrypt the vault into your Keychain (cache mode)")
    s.set_defaults(func=cmd_sync)

    s = sub.add_parser("get", help="print one secret's value")
    s.add_argument("name")
    s.set_defaults(func=cmd_get)

    s = sub.add_parser("lock", help="purge decrypted secrets / re-lock the key")
    s.set_defaults(func=cmd_lock)

    s = sub.add_parser("protect-key", help="encrypt the vault key with a passphrase")
    s.set_defaults(func=cmd_protect_key)

    s = sub.add_parser("unprotect-key", help="remove passphrase protection")
    s.set_defaults(func=cmd_unprotect_key)

    s = sub.add_parser("unlock", help="unlock the passphrase-protected key for this session")
    s.set_defaults(func=cmd_unlock)

    s = sub.add_parser("config", help="view/change settings (cache, autolock, log)")
    s.add_argument("key", nargs="?", choices=["cache", "log", "autolock", "touchid"])
    s.add_argument("value", nargs="?")
    s.set_defaults(func=cmd_config)

    s = sub.add_parser("log", help="show the access log")
    s.add_argument("--tail", type=int, default=0, help="show only the last N lines")
    s.set_defaults(func=cmd_log)

    s = sub.add_parser("list", help="list secret names (no values)")
    s.add_argument("prefix", nargs="?", help="only names under this folder/project")
    s.set_defaults(func=cmd_list)

    s = sub.add_parser("folders", help="list folders/projects")
    s.set_defaults(func=cmd_folders)

    s = sub.add_parser("import", help="scan a dir for .env files and import them")
    s.add_argument("dir")
    s.add_argument("--project", help="project folder (default: directory name)")
    s.add_argument("--apply", action="store_true", help="import (default: dry run)")
    s.add_argument("--overwrite", action="store_true", help="replace existing secrets")
    s.set_defaults(func=cmd_import)

    s = sub.add_parser("env", help="print a whole folder as export/.env lines")
    s.add_argument("prefix", help="folder/project name")
    s.add_argument("--dotenv", action="store_true",
                   help="KEY=VALUE lines (no 'export '), for writing a .env file")
    s.set_defaults(func=cmd_env)

    s = sub.add_parser("set", help="add/update a secret")
    s.add_argument("name")
    s.add_argument("value", nargs="?", help="omit to be prompted (hidden)")
    s.set_defaults(func=cmd_set)

    s = sub.add_parser("rm", help="remove a secret")
    s.add_argument("name")
    s.set_defaults(func=cmd_rm)

    s = sub.add_parser("members", help="show who can read the vault")
    s.set_defaults(func=cmd_members)

    s = sub.add_parser("add-member", help="add a teammate's public key")
    s.add_argument("alias")
    s.add_argument("pubkey")
    s.set_defaults(func=cmd_add_member)

    s = sub.add_parser("pubkey", help="print your age public key")
    s.set_defaults(func=cmd_pubkey)

    s = sub.add_parser("gui", help="open the localhost web GUI")
    s.add_argument("--port", type=int, default=8782)
    s.add_argument("--no-open", action="store_true",
                   help="don't auto-open the browser")
    s.set_defaults(func=cmd_gui)

    return p


def main():
    args = build_parser().parse_args()
    try:
        args.func(args)
    except Locked:
        die("vault key is locked. Run `envkeep unlock` (or unlock in the app).")


if __name__ == "__main__":
    main()
